<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Turboly Tasks" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body class="min-h-screen bg-[#f5f5f7] text-slate-950 antialiased">
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute left-1/2 top-[-12rem] h-[28rem] w-[28rem] -translate-x-1/2 rounded-full bg-blue-200/35 blur-3xl"></div>
      <div class="absolute bottom-[-10rem] right-[-6rem] h-[24rem] w-[24rem] rounded-full bg-slate-300/40 blur-3xl"></div>
    </div>

    <header class="sticky top-0 z-20 border-b border-white/60 bg-white/70 backdrop-blur-2xl">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
        <%= link_to root_path, class: "flex items-center gap-3" do %>
          <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-slate-950 text-sm font-semibold text-white shadow-lg shadow-slate-900/15">TA</span>
          <span>
            <span class="block text-sm font-semibold tracking-tight">Turboly Tasks</span>
            <span class="hidden text-xs text-slate-500 sm:block">Rails 7.2 · MySQL · Tailwind</span>
          </span>
        <% end %>

        <div class="flex items-center gap-2 text-sm">
          <% if logged_in? %>
            <span class="hidden rounded-full bg-slate-100 px-3 py-1 text-slate-600 md:inline-flex"><%= current_user.email %></span>
            <%= button_to "Logout", logout_path, method: :delete, class: "rounded-full bg-slate-950 px-4 py-2 font-medium text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-slate-800" %>
          <% else %>
            <%= link_to "Login", login_path, class: "rounded-full px-4 py-2 font-medium text-slate-700 hover:bg-white" %>
            <%= link_to "Register", sign_up_path, class: "rounded-full bg-slate-950 px-4 py-2 font-medium text-white shadow-sm hover:bg-slate-800" %>
          <% end %>
        </div>
      </nav>
    </header>

    <main class="relative z-10 mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
      <% if notice.present? %>
        <div class="mb-6 rounded-3xl border border-emerald-200 bg-emerald-50/90 px-5 py-4 text-sm text-emerald-800 shadow-sm"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-6 rounded-3xl border border-rose-200 bg-rose-50/90 px-5 py-4 text-sm text-rose-800 shadow-sm"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>

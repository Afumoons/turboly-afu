<section class="mx-auto max-w-2xl rounded-[2rem] border border-white/70 bg-white/85 p-8 shadow-xl shadow-slate-900/5">
  <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Task detail</p>
  <h1 class="mt-3 text-3xl font-semibold tracking-tight"><%= @task.description %></h1>
  <dl class="mt-6 grid gap-4 sm:grid-cols-2">
    <div class="rounded-2xl bg-slate-100 p-4">
      <dt class="text-sm text-slate-500">Due date</dt>
      <dd class="mt-1 font-semibold"><%= @task.due_date.strftime("%b %-d, %Y") %></dd>
    </div>
    <div class="rounded-2xl bg-slate-100 p-4">
      <dt class="text-sm text-slate-500">Priority</dt>
      <dd class="mt-1 font-semibold"><%= @task.priority_name %></dd>
    </div>
  </dl>
  <div class="mt-8 flex gap-3">
    <%= link_to "Edit", edit_task_path(@task), class: "rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white" %>
    <%= link_to "Back", tasks_path, class: "rounded-full bg-slate-100 px-5 py-3 text-sm font-semibold text-slate-700" %>
  </div>
</section>
